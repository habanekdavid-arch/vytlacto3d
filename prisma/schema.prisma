generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  name         String
  email        String   @unique
  passwordHash String
  phone        String?

  accountType  String   @default("PERSON")
  vatPayer     Boolean  @default(false)

  companyName  String?
  ico          String?
  dic          String?
  icDph        String?
  contactPerson String?

  billingStreet  String?
  billingCity    String?
  billingZip     String?
  billingCountry String?

  shippingName    String?
  shippingContact String?
  shippingStreet  String?
  shippingCity    String?
  shippingZip     String?
  shippingCountry String?

  orders       Order[]
}

model Order {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  status                String   @default("PENDING")

  fileKey               String
  fileName              String

  analysis              Json
  config                Json
  pricing               Json

  stripeSessionId       String?  @unique
  stripePaymentIntentId String?
  customerEmail         String?
  paidTotalEur          Float?

  shippingAddress       Json?
  shippingCost          Json?
  shippingMethod        String?

  accountType           String?
  phone                 String?
  vatPayer     Boolean  @default(false)

  companyName           String?
  ico                   String?
  dic                   String?
  icDph                 String?
  contactPerson         String?

  billingAddress        Json?
  deliveryAddress       Json?

  userId                String?
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}